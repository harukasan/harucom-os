{
  "$schema": "https://raw.githubusercontent.com/OpenLightingProject/open-fixture-library/master/schemas/fixture.json",
  "name": "SHEHDS 80W LED Spot Light",
  "categories": ["Moving Head"],
  "availableChannels": {
    "Pan": {
      "fineChannelAliases": ["Pan fine"],
      "capability": { "type": "Pan", "angleStart": "0%", "angleEnd": "100%" }
    },
    "Tilt": {
      "fineChannelAliases": ["Tilt fine"],
      "capability": { "type": "Tilt", "angleStart": "0%", "angleEnd": "100%" }
    },
    "Pan/Tilt Speed": {
      "capability": { "type": "PanTiltSpeed", "speedStart": "fast", "speedEnd": "slow" }
    },
    "Dimmer": {
      "capability": { "type": "Intensity" }
    },
    "Strobe": {
      "defaultValue": 0,
      "capabilities": [
        { "dmxRange": [0, 15], "type": "ShutterStrobe", "shutterEffect": "Open" },
        { "dmxRange": [16, 251], "type": "ShutterStrobe", "shutterEffect": "Strobe",
          "speedStart": "slow", "speedEnd": "fast" },
        { "dmxRange": [252, 255], "type": "ShutterStrobe", "shutterEffect": "Open" }
      ]
    },
    "Color Wheel": {
      "capabilities": [
        { "dmxRange": [0, 7], "type": "WheelSlot", "slotNumber": 1, "comment": "white" },
        { "dmxRange": [8, 15], "type": "WheelSlot", "slotNumber": 2, "comment": "red" },
        { "dmxRange": [16, 23], "type": "WheelSlot", "slotNumber": 3, "comment": "green" },
        { "dmxRange": [24, 31], "type": "WheelSlot", "slotNumber": 4, "comment": "blue" },
        { "dmxRange": [32, 39], "type": "WheelSlot", "slotNumber": 5, "comment": "yellow" },
        { "dmxRange": [40, 47], "type": "WheelSlot", "slotNumber": 6, "comment": "pink" },
        { "dmxRange": [48, 55], "type": "WheelSlot", "slotNumber": 7, "comment": "light green" },
        { "dmxRange": [56, 63], "type": "WheelSlot", "slotNumber": 8, "comment": "light blue" },
        { "dmxRange": [64, 71], "type": "WheelSlot", "slotNumber": 9, "comment": "light blue + white" },
        { "dmxRange": [72, 79], "type": "WheelSlot", "slotNumber": 10, "comment": "light blue + light green" },
        { "dmxRange": [80, 87], "type": "WheelSlot", "slotNumber": 11, "comment": "light green + pink" },
        { "dmxRange": [88, 95], "type": "WheelSlot", "slotNumber": 12, "comment": "pink + yellow" },
        { "dmxRange": [96, 103], "type": "WheelSlot", "slotNumber": 13, "comment": "yellow + blue" },
        { "dmxRange": [104, 111], "type": "WheelSlot", "slotNumber": 14, "comment": "blue + green" },
        { "dmxRange": [112, 119], "type": "WheelSlot", "slotNumber": 15, "comment": "green + red" },
        { "dmxRange": [120, 127], "type": "WheelSlot", "slotNumber": 16, "comment": "red + white" },
        { "dmxRange": [192, 255], "type": "WheelRotation", "speedStart": "slow CW", "speedEnd": "fast CW", "comment": "rotate" }
      ]
    },
    "Gobo Wheel": {
      "capabilities": [
        { "dmxRange": [4, 4], "type": "WheelSlot", "slotNumber": 1, "comment": "open" },
        { "dmxRange": [13, 13], "type": "WheelSlot", "slotNumber": 2, "comment": "gobo1" },
        { "dmxRange": [21, 21], "type": "WheelSlot", "slotNumber": 3, "comment": "gobo2" },
        { "dmxRange": [30, 30], "type": "WheelSlot", "slotNumber": 4, "comment": "gobo3" },
        { "dmxRange": [38, 38], "type": "WheelSlot", "slotNumber": 5, "comment": "gobo4" },
        { "dmxRange": [47, 47], "type": "WheelSlot", "slotNumber": 6, "comment": "gobo5" },
        { "dmxRange": [55, 55], "type": "WheelSlot", "slotNumber": 7, "comment": "gobo6" },
        { "dmxRange": [64, 64], "type": "WheelSlot", "slotNumber": 8, "comment": "gobo7" },
        { "dmxRange": [72, 72], "type": "WheelShake", "slotNumber": 8, "comment": "gobo7 shake" },
        { "dmxRange": [81, 81], "type": "WheelShake", "slotNumber": 7, "comment": "gobo6 shake" },
        { "dmxRange": [89, 89], "type": "WheelShake", "slotNumber": 6, "comment": "gobo5 shake" },
        { "dmxRange": [98, 98], "type": "WheelShake", "slotNumber": 5, "comment": "gobo4 shake" },
        { "dmxRange": [106, 106], "type": "WheelShake", "slotNumber": 4, "comment": "gobo3 shake" },
        { "dmxRange": [115, 115], "type": "WheelShake", "slotNumber": 3, "comment": "gobo2 shake" },
        { "dmxRange": [123, 123], "type": "WheelShake", "slotNumber": 2, "comment": "gobo1 shake" },
        { "dmxRange": [192, 255], "type": "WheelRotation", "speedStart": "slow CW", "speedEnd": "fast CW", "comment": "rotate" }
      ]
    },
    "Focus": {
      "capability": { "type": "Focus", "distanceStart": "near", "distanceEnd": "far" }
    },
    "Prism": {
      "capabilities": [
        { "dmxRange": [0, 15], "type": "NoFunction", "comment": "off" },
        { "dmxRange": [16, 127], "type": "Prism", "comment": "prism in" },
        { "dmxRange": [128, 255], "type": "PrismRotation", "speedStart": "slow CW", "speedEnd": "fast CW", "comment": "rotate" }
      ]
    },
    "Auto Programs": {
      "capability": { "type": "Generic", "comment": "motor auto programs" }
    },
    "Function": {
      "capabilities": [
        { "dmxRange": [0, 149], "type": "NoFunction" },
        { "dmxRange": [150, 199], "type": "Effect", "effectName": "Full auto" },
        { "dmxRange": [200, 249], "type": "Effect", "effectName": "Sound control", "soundControlled": true },
        { "dmxRange": [250, 255], "type": "Maintenance", "comment": "reset" }
      ]
    }
  },
  "modes": [
    {
      "name": "13-channel",
      "shortName": "13ch",
      "channels": [
        "Pan", "Pan fine", "Tilt", "Tilt fine", "Pan/Tilt Speed",
        "Dimmer", "Strobe", "Color Wheel", "Gobo Wheel", "Focus",
        "Prism", "Auto Programs", "Function"
      ]
    },
    {
      "name": "10-channel",
      "shortName": "10ch",
      "channels": [
        "Pan", "Tilt", "Dimmer", "Strobe", "Color Wheel",
        "Gobo Wheel", "Focus", "Prism", "Pan/Tilt Speed", "Function"
      ]
    }
  ]
}
