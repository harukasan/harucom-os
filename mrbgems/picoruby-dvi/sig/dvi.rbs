class DVI
  TEXT_MODE: Integer
  GRAPHICS_MODE: Integer

  def self.set_mode: (Integer mode) -> void
  def self.wait_vsync: () -> void
  def self.frame_count: () -> Integer

  class Color
    def self.rgb: (Integer r, Integer g, Integer b) -> Integer
  end

  class Text
    COLS: Integer
    ROWS: Integer

    BLACK: Integer
    BLUE: Integer
    GREEN: Integer
    CYAN: Integer
    RED: Integer
    MAGENTA: Integer
    BROWN: Integer
    LIGHT_GRAY: Integer
    DARK_GRAY: Integer
    LIGHT_BLUE: Integer
    LIGHT_GREEN: Integer
    LIGHT_CYAN: Integer
    LIGHT_RED: Integer
    LIGHT_MAGENTA: Integer
    YELLOW: Integer
    WHITE: Integer

    def self.put_char: (Integer col, Integer row, Integer ch, Integer attr) -> void
    def self.put_string: (Integer col, Integer row, String str, Integer attr) -> void
    def self.clear: (Integer attr) -> void
    def self.clear_line: (Integer row, Integer attr) -> void
    def self.set_palette: (Integer index, Integer color) -> void
    def self.get_palette: (Integer index) -> Integer
    def self.attr: (Integer fg, Integer bg) -> Integer
  end

  class Graphics
    def self.width: () -> Integer
    def self.height: () -> Integer
    def self.set_resolution: (Integer width, Integer height) -> void
    FONT_8X8: Integer
    FONT_MPLUS_12: Integer
    FONT_FIXED_4X6: Integer
    FONT_FIXED_5X7: Integer
    FONT_FIXED_6X13: Integer
    FONT_SPLEEN_5X8: Integer
    FONT_SPLEEN_8X16: Integer
    FONT_SPLEEN_12X24: Integer
    FONT_DENKICHIP: Integer
    FONT_MPLUS_J12: Integer
    FONT_DENKICHIP_J: Integer

    BLEND_REPLACE: Integer
    BLEND_ADD: Integer
    BLEND_SUBTRACT: Integer
    BLEND_MULTIPLY: Integer
    BLEND_SCREEN: Integer
    BLEND_ALPHA: Integer

    def self.commit: () -> void
    def self.set_blend_mode: (Integer mode) -> void
    def self.set_alpha: (Integer alpha) -> void
    def self.set_pixel: (Integer x, Integer y, Integer color) -> void
    def self.get_pixel: (Integer x, Integer y) -> Integer
    def self.fill: (Integer color) -> void
    def self.fill_rect: (Integer x, Integer y, Integer w, Integer h, Integer color) -> void
    def self.draw_text: (Integer x, Integer y, String text, Integer color, ?Integer font, ?Integer wide_font) -> void
    def self.draw_rect: (Integer x, Integer y, Integer w, Integer h, Integer color) -> void
    def self.fill_circle: (Integer cx, Integer cy, Integer r, Integer color) -> void
    def self.draw_circle: (Integer cx, Integer cy, Integer r, Integer color) -> void
    def self.fill_arc: (Integer cx, Integer cy, Integer r, Float start_angle, Float stop_angle, Integer color) -> void
    def self.draw_arc: (Integer cx, Integer cy, Integer r, Float start_angle, Float stop_angle, Integer color) -> void
    def self.fill_triangle: (Integer x0, Integer y0, Integer x1, Integer y1, Integer x2, Integer y2, Integer color) -> void
    def self.fill_ellipse: (Integer cx, Integer cy, Integer rx, Integer ry, Integer color) -> void
    def self.draw_ellipse: (Integer cx, Integer cy, Integer rx, Integer ry, Integer color) -> void
    def self.draw_thick_line: (Integer x0, Integer y0, Integer x1, Integer y1, Integer thickness, Integer color) -> void
    def self.font_height: (Integer font) -> Integer
    def self.text_width: (String text, ?Integer font, ?Integer wide_font) -> Integer
    def self.draw_line: (Integer x0, Integer y0, Integer x1, Integer y1, Integer color) -> void
    def self.draw_image: (String data, Integer x, Integer y, Integer w, Integer h) -> void
    def self.draw_image_masked: (String data, String mask, Integer x, Integer y, Integer w, Integer h) -> void
    def self.draw_image_affine: (String data, Integer w, Integer h, Integer origin_x, Integer origin_y, Float m00, Float m01, Float m10, Float m11, Float tx, Float ty) -> void
    def self.draw_image_masked_affine: (String data, String mask, Integer w, Integer h, Integer origin_x, Integer origin_y, Float m00, Float m01, Float m10, Float m11, Float tx, Float ty) -> void
  end
end
